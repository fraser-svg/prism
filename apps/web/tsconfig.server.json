{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist/server",
    "noEmit": false,
    "types": ["node"],
    "paths": {
      "@prism/core": ["../../packages/core/src/index.ts"],
      "@prism/memory": ["../../packages/memory/src/index.ts"],
      "@prism/orchestrator": ["../../packages/orchestrator/src/index.ts"],
      "@prism/orchestrator/*": ["../../packages/orchestrator/src/*"],
      "@prism/guardian": ["../../packages/guardian/src/index.ts"],
      "@prism/execution": ["../../packages/execution/src/index.ts"],
      "@prism/workspace": ["../../packages/workspace/src/index.ts"],
      "@prism/ui": ["../../packages/ui/src/index.ts"]
    }
  },
  "include": ["server/**/*"]
}
