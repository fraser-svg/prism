{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "dist/renderer",
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": []
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/shared/result.ts"
  ],
  "exclude": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/ipc-channels.ts",
    "src/shared/*.test.ts"
  ]
}
